{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BeatSync Output Schema v0.1",
  "type": "object",
  "required": ["metadata", "tempo", "key", "rhythm", "structure", "energy"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["source_file", "duration_sec", "analysis_version"],
      "properties": {
        "source_file": {"type": "string"},
        "duration_sec": {"type": "number"},
        "analysis_version": {"type": "string"}
      }
    },
    "tempo": {
      "type": "object",
      "required": ["bpm", "confidence"],
      "properties": {
        "bpm": {"type": "number"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "key": {
      "type": "object",
      "required": ["name", "confidence"],
      "properties": {
        "name": {"type": "string"},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "rhythm": {
      "type": "object",
      "required": ["beats", "bars"],
      "properties": {
        "beats": {
          "type": "array",
          "items": {"type": "number"}
        },
        "bars": {
          "type": "array",
          "items": {"type": "number"}
        }
      }
    },
    "structure": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["label", "start", "end", "confidence"],
        "properties": {
          "label": {"type": "string"},
          "start": {"type": "number"},
          "end": {"type": "number"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "energy": {
      "type": "object",
      "required": ["curve", "peaks"],
      "properties": {
        "curve": {
          "type": "array",
          "items": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "peaks": {
          "type": "array",
          "items": {"type": "number"}
        }
      }
    }
  }
}
